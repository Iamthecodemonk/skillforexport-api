# SkillForExport API Environment Variables
# Copy this file to .env and update with your actual values

# ===== APPLICATION =====
PORT=3000
NODE_ENV=development

# ===== LOGGING =====
# Options: silent | error | warn | info | debug
# Default: info
# Set to 'silent' in production to disable all logging
LOG_LEVEL=info

# ===== DATABASE (MySQL) =====
# Local development
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=skillforexport123
DATABASE_NAME=skillforexport

# Docker setup (uncomment if using Docker Compose)
# DATABASE_URL=mysql://root:skillforexport123@mysql:3306/skillforexport

# ===== REDIS =====
# Deployment environment determines connection behavior:
# - 'local' (default): Uses localhost for all services
# - 'docker': Uses service names (redis, mysql) for Docker Compose
DEPLOYMENT_ENV=local
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== AUTHENTICATION (JWT) =====
# IMPORTANT: Change these values in production!
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ===== EMAIL/SMTP CONFIGURATION =====
# Emails are optional - registration works without SMTP configured
# 
# Gmail Setup (recommended for testing):
#   1. Enable 2FA on your Google Account: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Select Mail → Windows Computer
#   4. Copy the 16-character password → paste as SMTP_PASS
#
# Company Mail Server Setup:
#   Contact your email admin for SMTP credentials
#   Usually uses port 465 (SSL) or 587 (TLS)
#
# Leave SMTP_USER and SMTP_PASS empty to disable email sending

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=notifications@skillforexport.com

# ===== APPLICATION SETTINGS =====
# Override with your app URL (used in email templates)
APP_URL=http://localhost:3000

# ===== DEBUGGING =====
# Set to 'true' to enable verbose debug logging (development only)
DEBUG=false

# ===== CLOUDINARY (optional for file uploads) =====
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
